APP_ENV=development
DATABASE_URL=mysql+pymysql://theater_app:replace-me@127.0.0.1:3306/theater_cast_scheduling
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ALLOWED_ORIGINS=http://localhost:7003
ALLOW_DEMO_ADMIN=true
ACTOR_PORTAL_URL=http://localhost:7003/actor
SETTINGS_ENCRYPTION_KEY=
# 设为 0 可关闭应用侧慢查询日志；生产建议结合数据库慢查询日志共同使用。
SLOW_QUERY_THRESHOLD_MS=500
